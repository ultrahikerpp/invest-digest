# Copy this file to .env and fill in your keys
# .env is gitignored and will never be committed

# Gmail SMTP (for notify command)
# Generate App Password at: myaccount.google.com/apppasswords
GMAIL_USER=123@gmail.com
GMAIL_APP_PASSWORD=your_16char_app_password_here

# Supabase (for subscriber notifications)
# Create a free project at supabase.com, then find these in Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...    # Safe to expose in browser JS (protected by RLS)
SUPABASE_SERVICE_KEY=eyJ... # Server-side only, never commit this

# Static site base URL (used in confirmation/unsubscribe email links)
SITE_BASE_URL=https://yocoppp.github.io/investment-digest
